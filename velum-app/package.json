{
  "name": "velum-app",
  "version": "1.0.0",
  "description": "VELUM — Portal nativo de atletas (multi-gym, white-label)",
  "scripts": {
    "build": "node scripts/build.js",
    "build:move": "VELUM_BRAND=move node scripts/build.js",
    "build:watch": "node scripts/build.js --watch",
    "sync": "npx cap sync",
    "sync:ios": "npx cap sync ios",
    "sync:android": "npx cap sync android",
    "open:ios": "npx cap open ios",
    "open:android": "npx cap open android",
    "run:ios": "npx cap run ios",
    "run:android": "npx cap run android",
    "deploy:velum": "node scripts/build.js && npx cap sync",
    "deploy:move": "VELUM_BRAND=move node scripts/build.js && VELUM_BRAND=move npx cap sync",
    "setup": "bash scripts/setup.sh",
    "new-brand": "node scripts/new-brand.js"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/camera": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/local-notifications": "^6.0.0",
    "@capacitor/network": "^6.0.0",
    "@capacitor/push-notifications": "^6.0.0",
    "@capacitor/share": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.0.0",
    "typescript": "^6.0.3"
  }
}
