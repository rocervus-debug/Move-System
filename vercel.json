{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": ".",
  "installCommand": null,
  "framework": null,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "move-system.vercel.app" }],
      "destination": "https://myvelum.app/$1",
      "permanent": true
    },
    {
      "source": "/VELUM_Sistema_Interno.html",
      "destination": "/app",
      "permanent": false
    }
  ],
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/app", "dest": "/VELUM_Sistema_Interno.html" },
    { "src": "/login", "dest": "/VELUM_Sistema_Interno.html" },
    { "src": "/velum", "dest": "/VELUM_Sistema_Interno.html" },
    { "src": "/atleta", "dest": "/atleta.html" },
    { "src": "/portal", "dest": "/atleta.html" },
    { "src": "/checkin", "dest": "/checkin.html" },
    { "src": "/stripe-callback", "dest": "/stripe-callback.html" },
    { "src": "/success-payment", "dest": "/success.html" },
    { "src": "/storefront-success", "dest": "/success-storefront.html" },
    { "src": "/registro", "dest": "/registro.html" },
    { "src": "/success", "dest": "/success.html" },
    { "src": "/g/(?<slug>[a-z0-9-]+)", "dest": "/storefront.html?slug=$slug" },
    { "src": "/sitemap.xml", "dest": "https://savzjanpydyjtrgdkllx.supabase.co/functions/v1/storefront-sitemap" },
    { "src": "/terminos", "dest": "/terminos.html" },
    { "src": "/privacidad", "dest": "/privacidad.html" },
    { "src": "/VELUM_Sistema_Interno.html", "headers": { "Location": "/app" }, "status": 302 },
    { "src": "/404", "dest": "/404.html" },
    { "src": "/404.html", "dest": "/404.html" },
    { "src": "/(.*)\\.html", "dest": "/$1.html" },
    { "src": "/(.*\\.(png|ico|svg|jpg|jpeg|webp|gif|css|js|mjs|json|xml|txt|woff|woff2|webmanifest|map))", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/$1", "continue": true },
    { "src": "/(.*)", "dest": "/404.html", "status": 404 }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(self), microphone=(), geolocation=(self), payment=(self), interest-cohort=()" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" },
        { "key": "Content-Security-Policy", "value": "default-src 'self' https: data: blob:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https:; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: blob: https:; font-src 'self' data: https:; connect-src 'self' https: wss:; frame-src 'self' https://www.google.com https://www.youtube.com https://www.youtube-nocookie.com https://js.stripe.com https://hooks.stripe.com https://checkout.stripe.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self' https:; upgrade-insecure-requests" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    }
  ]
}
